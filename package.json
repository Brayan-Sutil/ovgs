{
  "name": "ovgs",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --parallel --filter @ovgs/api --filter @ovgs/web dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @ovgs/api db:generate",
    "db:push": "pnpm --filter @ovgs/api db:push",
    "db:seed": "pnpm --filter @ovgs/api db:seed"
  }
}
